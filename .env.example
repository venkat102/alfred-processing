# Alfred Processing App — Environment Configuration
# Copy to .env and update values for your environment.
#
# Start modes:
#   Remote Ollama:  docker compose up -d
#   Local Ollama:   docker compose --profile local-llm up -d
#   Local + GPU:    docker compose --profile local-llm --profile gpu up -d

# ── Security (REQUIRED) ─────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=your-secret-key-here

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001                  # Use 8001 to avoid conflict with Frappe (which uses 8000)
WORKERS=2
DEBUG=false

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── LLM Configuration ───────────────────────────────────────────
# These are fallbacks - Alfred Settings on the Frappe site takes priority.
# Model must be a CODER-tuned model (qwen2.5-coder, codestral, codegemma)
# or the Developer agent drifts into prose. Full sizing + tier picks:
# alfred_client/docs/admin-guide.md > "Recommended Ollama models".
#
# Option A: Remote Ollama (your server, e.g. a GPU box)
#   FALLBACK_LLM_MODEL=ollama/qwen2.5-coder:14b
#   FALLBACK_LLM_BASE_URL=http://135.13.20.57:11434
#   FALLBACK_LLM_API_KEY=          (leave empty unless proxy needs auth)
#
# Option B: Local Ollama (Docker container, use --profile local-llm)
#   FALLBACK_LLM_MODEL=ollama/qwen2.5-coder:7b
#   FALLBACK_LLM_BASE_URL=http://ollama:11434
#   FALLBACK_LLM_API_KEY=
#
# Option C: Cloud provider (Anthropic, OpenAI, etc.)
#   FALLBACK_LLM_MODEL=anthropic/claude-sonnet-4-20250514
#   FALLBACK_LLM_BASE_URL=         (leave empty for cloud)
#   FALLBACK_LLM_API_KEY=sk-ant-api03-your-key-here
#
FALLBACK_LLM_MODEL=
FALLBACK_LLM_BASE_URL=
FALLBACK_LLM_API_KEY=

# ── Ollama (only if using --profile local-llm) ──────────────────
OLLAMA_PORT=11434

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated origins. Use * for dev, restrict in production.
ALLOWED_ORIGINS=*

# ── Admin Portal (optional, for SaaS) ───────────────────────────
ADMIN_PORTAL_URL=
ADMIN_SERVICE_KEY=

# ── CrewAI telemetry opt-out ────────────────────────────────────
# CrewAI ships with outbound telemetry to its own SaaS endpoint. These
# flags disable the phone-home and skip the embedded OTel SDK init (also
# trims cold-start). alfred/main.py also sets these three via
# os.environ.setdefault() at import time, so forgetting them here still
# boots safely. Leave them set unless you specifically want to send
# agent run metadata to CrewAI.
CREWAI_DISABLE_TELEMETRY=true
CREWAI_DISABLE_TRACKING=true
OTEL_SDK_DISABLED=true

# ── Feature flags (all optional, all default OFF) ──────────────────
# Full reference table in README.md > "Feature Flags". The specialist
# stack composes: PER_INTENT_BUILDERS < MODULE_SPECIALISTS <
# MULTI_MODULE - each later flag is a no-op without the one before it.
#
# Accept any of 1 / true / yes (case-insensitive) to enable.
#
# Specialist stack (Dev mode customization output):
# ALFRED_PER_INTENT_BUILDERS=1    # swap generic Developer for intent-specific builder
# ALFRED_MODULE_SPECIALISTS=1     # layer per-module domain context (needs PER_INTENT_BUILDERS)
# ALFRED_MULTI_MODULE=1           # detect primary + up to 2 secondary modules (needs MODULE_SPECIALISTS)
# ALFRED_REPORT_HANDOFF=1         # Insights -> Report "Save as Report" button (needs PER_INTENT_BUILDERS)
#
# Three-mode chat + reflection:
ALFRED_ORCHESTRATOR_ENABLED=1     # enable chat / insights / plan / dev routing (fixes "hi" -> "unable to classify")
# ALFRED_REFLECTION_ENABLED=1     # post-crew reflection drops items the user didn't ask for
#
# Observability:
# ALFRED_TRACING_ENABLED=1        # per-phase JSONL span tracing
# ALFRED_TRACE_PATH=./alfred_trace.jsonl  # whitelist: cwd / $HOME / tempfile.gettempdir() / /tmp / /var/tmp
# ALFRED_TRACE_STDOUT=1           # also emit a human-readable one-line summary to stderr
#
# Rarely-used / advanced:
# ALFRED_FKB_DIR=/path/to/frappe_kb       # override Frappe KB directory (CI / non-standard bench layouts)
# ALFRED_PHASE1_DISABLED=1                # opt out of Phase 1 MCP budget cap + dedup cache (benchmark only)
