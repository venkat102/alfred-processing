# Alfred Processing App — Environment Configuration
# Copy to .env and update values for your environment

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
DEBUG=false

# Security — REQUIRED: change this in production
API_SECRET_KEY=your-secret-key-here

# Redis
REDIS_URL=redis://redis:6379/0

# Fallback LLM (used when client doesn't provide its own config)
FALLBACK_LLM_MODEL=
FALLBACK_LLM_API_KEY=
FALLBACK_LLM_BASE_URL=
