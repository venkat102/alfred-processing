# Alfred Processing App — Environment Configuration
# Copy to .env and update values for your environment.
#
# Start modes:
#   Remote Ollama:  docker compose up -d
#   Local Ollama:   docker compose --profile local-llm up -d
#   Local + GPU:    docker compose --profile local-llm --profile gpu up -d

# ── Security (REQUIRED) ─────────────────────────────────────────
# Generate each with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# API_SECRET_KEY: bearer token for every REST request and WebSocket
#   handshake. Compared in constant time.
# JWT_SIGNING_KEY: HMAC key for WebSocket-handshake JWTs. MUST differ
#   from API_SECRET_KEY and be >= 32 bytes. Leaving blank falls back
#   to API_SECRET_KEY (legacy shared-key mode) with a loud deprecation
#   warning at startup; set an explicit value to enable full key
#   separation. Rollout: (1) JWT issuer (admin portal / client app)
#   flips to the new secret, (2) set JWT_SIGNING_KEY here to match,
#   (3) restart — new JWTs verify, old JWTs fail so users re-auth.
API_SECRET_KEY=your-secret-key-here
JWT_SIGNING_KEY=

# JWT_ISSUER + JWT_AUDIENCE (TD-M1). When BOTH set, JWTs must carry
# matching `iss` and `aud` claims or the server rejects them. Prevents
# cross-instance token replay if multiple Alfred deployments share a
# signing key. Unset = no enforcement, backward-compat with pre-TD-M1
# tokens. Set these together once your JWT issuer (admin portal) is
# embedding both claims.
#   JWT_ISSUER=admin.example.com
#   JWT_AUDIENCE=alfred-processing.prod
JWT_ISSUER=
JWT_AUDIENCE=

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001                  # Use 8001 to avoid conflict with Frappe (which uses 8000)
# TD-H7: WORKERS=1 per container is the supported configuration.
# Per-connection state (WebSocket, MCP pending-response futures) lives
# in process memory — bumping this >1 silently breaks session state on
# load-balancer reconnect. Scale horizontally via container replicas
# with sticky WebSocket routing at the LB. main.py logs a WARNING if
# you override this.
WORKERS=1
DEBUG=false

# Log level — DEBUG | INFO | WARNING | ERROR | CRITICAL.
# INFO in production; DEBUG only for local dev. DEBUG emits LLM prompts
# and site_config into stdout, which drives up log cost and risks PII /
# API-key leakage. Sensitive dict values (api_key, jwt_token, password,
# etc.) are always redacted, but the safer default is to avoid emitting
# them in the first place.
LOG_LEVEL=INFO

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
# Connection pool size per FastAPI worker. 20 is fine for most
# deployments; raise if you see "pool exhausted" warnings under load.
# REDIS_POOL_SIZE=20
# Socket timeout in seconds for individual Redis ops.
# REDIS_SOCKET_TIMEOUT=5
# Task-state TTL in seconds. 7 days by default. Prevents unbounded
# Redis growth from conversation task-state blobs. Override only for
# long-running workflows that exceed this window.
TASK_STATE_TTL_SECONDS=604800

# ── LLM Configuration ───────────────────────────────────────────
# These are fallbacks - Alfred Settings on the Frappe site takes priority.
# Model must be a CODER-tuned model (qwen2.5-coder, codestral, codegemma)
# or the Developer agent drifts into prose. Full sizing + tier picks:
# alfred_client/docs/admin-guide.md > "Recommended Ollama models".
#
# LLM call thread pool (TD-H6). Size is the max concurrent LLM
# requests per FastAPI worker before new calls queue. Bump if you
# see queue latency on high-concurrency sites; watch memory — each
# thread stack is ~8 MB on macOS.
# LLM_POOL_SIZE=16

# Option A: Remote Ollama (your server, e.g. a GPU box)
#   FALLBACK_LLM_MODEL=ollama/qwen2.5-coder:14b
#   FALLBACK_LLM_BASE_URL=http://135.13.20.57:11434
#   FALLBACK_LLM_API_KEY=          (leave empty unless proxy needs auth)
#
# Option B: Local Ollama (Docker container, use --profile local-llm)
#   FALLBACK_LLM_MODEL=ollama/qwen2.5-coder:7b
#   FALLBACK_LLM_BASE_URL=http://ollama:11434
#   FALLBACK_LLM_API_KEY=
#
# Option C: Cloud provider (Anthropic, OpenAI, etc.)
#   FALLBACK_LLM_MODEL=anthropic/claude-sonnet-4-20250514
#   FALLBACK_LLM_BASE_URL=         (leave empty for cloud)
#   FALLBACK_LLM_API_KEY=sk-ant-api03-your-key-here
#
FALLBACK_LLM_MODEL=
FALLBACK_LLM_BASE_URL=
FALLBACK_LLM_API_KEY=

# ── Ollama (only if using --profile local-llm) ──────────────────
OLLAMA_PORT=11434

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated origin allow-list.
#
# Dev (DEBUG=true): `*` accepted. Credentials are disabled automatically
#   so the `*` origin stays CORS-spec-compliant. Prints a loud WARNING at
#   startup so this mode is visible.
#
# Production (DEBUG=false): `*` is REJECTED. You MUST provide an explicit
#   list. `*` + allow_credentials=True is invalid per CORS spec; browsers
#   silently reject credentialed requests, so this safeguards against a
#   silently broken deploy.
#
# Prod example: https://yourapp.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ── Admin Portal (optional, for SaaS) ───────────────────────────
ADMIN_PORTAL_URL=
ADMIN_SERVICE_KEY=

# ── SSRF allow-list for client-supplied LLM URLs ────────────────
# The WebSocket handshake accepts site_config.llm_base_url from the
# client. Without validation a compromised client could point Alfred
# at cloud metadata (http://169.254.169.254/), localhost Redis, or
# internal admin services. Private IPs are blocked unless:
#   - DEBUG=true (dev): bypass enabled, warning logged per request
#   - Host appears in ALFRED_LLM_ALLOWED_HOSTS (prod): explicit allow
#
# Entries can be hostnames or CIDR blocks. Useful for a self-hosted
# Ollama on your private VPC in production.
#   Example: ALFRED_LLM_ALLOWED_HOSTS=ollama.internal.corp,10.243.88.0/24
ALFRED_LLM_ALLOWED_HOSTS=

# ── Alfred feature flags ────────────────────────────────────────
# All ALFRED_* flags accept "1", "true", "yes", or "on" (case-insensitive)
# as TRUE; anything else is FALSE. Canonical home: alfred/config.py
# (Settings class) — adding a new flag requires a Settings field + a
# call site, not just setting an env var.

# Three-mode chat orchestrator (dev / plan / insights / chat).
# Off = forces mode=dev, skips classifier.
ALFRED_ORCHESTRATOR_ENABLED=

# Agent reflection / self-critique pass in the crew pipeline.
ALFRED_REFLECTION_ENABLED=

# Specialist stack. Flag stack is nested:
#   PER_INTENT_BUILDERS  V1 - Builder agents per intent
#   MODULE_SPECIALISTS   V2 - domain context (needs V1)
#   MULTI_MODULE         V3 - primary + secondary (needs V2)
#   REPORT_HANDOFF       V4 - Insights -> Report handoff (needs V1)
ALFRED_PER_INTENT_BUILDERS=
ALFRED_MODULE_SPECIALISTS=
ALFRED_MULTI_MODULE=
ALFRED_REPORT_HANDOFF=

# Tracing — writes JSONL phase spans for offline analysis.
ALFRED_TRACING_ENABLED=
ALFRED_TRACE_PATH=alfred_trace.jsonl
ALFRED_TRACE_STDOUT=

# Legacy Phase 1 toggle (negative semantics — set to 1 to DISABLE).
ALFRED_PHASE1_DISABLED=

# Frappe Knowledge Base directory override. Leave blank for the
# bundled default under apps/alfred_client.
ALFRED_FKB_DIR=

# ── WebSocket tuning (advanced) ─────────────────────────────────
# Heartbeat ping interval in seconds. Clients with idle-timeout proxies
# in front may need this lowered (some cloud LBs cut idle >60s).
# WS_HEARTBEAT_INTERVAL=30

# ── Graceful shutdown (TD-M6) ───────────────────────────────────
# On SIGTERM, stop accepting new prompts and wait up to this many
# seconds for in-flight pipelines to finish. Kubernetes
# terminationGracePeriodSeconds on the pod spec should be >= this.
# GRACEFUL_SHUTDOWN_TIMEOUT=30

# ── CrewAI telemetry opt-out ────────────────────────────────────
# CrewAI ships with outbound telemetry to its own SaaS endpoint. These
# flags disable the phone-home and skip the embedded OTel SDK init (also
# trims cold-start). alfred/main.py also sets these three via
# os.environ.setdefault() at import time, so forgetting them here still
# boots safely. Leave them set unless you specifically want to send
# agent run metadata to CrewAI.
CREWAI_DISABLE_TELEMETRY=true
CREWAI_DISABLE_TRACKING=true
OTEL_SDK_DISABLED=true

# ── Feature flags (all optional, all default OFF) ──────────────────
# Full reference table in README.md > "Feature Flags". The specialist
# stack composes: PER_INTENT_BUILDERS < MODULE_SPECIALISTS <
# MULTI_MODULE - each later flag is a no-op without the one before it.
#
# Accept any of 1 / true / yes (case-insensitive) to enable.
#
# Specialist stack (Dev mode customization output):
# ALFRED_PER_INTENT_BUILDERS=1    # swap generic Developer for intent-specific builder
# ALFRED_MODULE_SPECIALISTS=1     # layer per-module domain context (needs PER_INTENT_BUILDERS)
# ALFRED_MULTI_MODULE=1           # detect primary + up to 2 secondary modules (needs MODULE_SPECIALISTS)
# ALFRED_REPORT_HANDOFF=1         # Insights -> Report "Save as Report" button (needs PER_INTENT_BUILDERS)
#
# Three-mode chat + reflection:
ALFRED_ORCHESTRATOR_ENABLED=1     # enable chat / insights / plan / dev routing (fixes "hi" -> "unable to classify")
# ALFRED_REFLECTION_ENABLED=1     # post-crew reflection drops items the user didn't ask for
#
# Observability:
# ALFRED_TRACING_ENABLED=1        # per-phase JSONL span tracing
# ALFRED_TRACE_PATH=./alfred_trace.jsonl  # whitelist: cwd / $HOME / tempfile.gettempdir() / /tmp / /var/tmp
# ALFRED_TRACE_STDOUT=1           # also emit a human-readable one-line summary to stderr
#
# Rarely-used / advanced:
# ALFRED_FKB_DIR=/path/to/frappe_kb       # override Frappe KB directory (CI / non-standard bench layouts)
# ALFRED_PHASE1_DISABLED=1                # opt out of Phase 1 MCP budget cap + dedup cache (benchmark only)
