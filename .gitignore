__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.env
# Timestamped .env backups created by scripts/rotate_api_secret_key.py
.env.bak.*
.venv/
venv/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage artefacts (pytest-cov writes these on every run).
.coverage
.coverage.*
coverage.xml
htmlcov/

# macOS noise
.DS_Store

# Raw benchmark run logs - ephemeral stdout capture from live pipeline
# runs, 400KB-800KB each. The structured JSON summaries in the same
# directory (baseline_*.json, phaseN_*.json) are what actually gate
# the phase comparisons and are committed.
benchmarks/*.log

# Local Claude Code state (per-machine; never commit)
.claude/

# CHANGELOG.md is intentionally NOT maintained in this repo - the git
# log + commit message style is the history of record. See TD-L5 in
# docs/tech-debt-backlog.md (marked Won't do) for the decision. Listed
# here so an upstream merge that adds a CHANGELOG.md doesn't silently
# reintroduce one.
CHANGELOG.md
